public class Pokemon {

    private String nome;
    private int hp;
    private int hpMax;
    private int attacco;
    private int difesa;
    private String tipo;

    private boolean megaEvoluto = false;
    private boolean superMossaUsata = false;

    public Pokemon(String nome, int hp, int attacco, int difesa, String tipo) {
        this.nome = nome;
        this.hp = hp;
        this.hpMax = hp;
        this.attacco = attacco;
        this.difesa = difesa;
        this.tipo = tipo;
    }

    public void attacca(Pokemon nemico) {
        double efficacia = calcolaEfficacia(this.tipo, nemico.tipo);
        int base = attacco - nemico.difesa;
        if (base < 1) base = 1;

        int danno = (int) (base * efficacia);
        if (danno < 1) danno = 1;

        nemico.riceviDanno(danno);
        System.out.println(nome + " attacca " + nemico.nome + " infliggendo " + danno + " danni.");
    }

    public void riceviDanno(int danno) {
        hp -= danno;
        if (hp < 0) {
            hp = 0;
            System.out.println(nome+" E' stato sconfitto!");
    }
    }

    public void usaPozione() {
        hp += 30;
        if (hp > hpMax) hp = hpMax;
        System.out.println(nome + " usa una pozione. HP: " + hp);
    }

    public void usaSuperMossa(Pokemon nemico) {
        if (superMossaUsata) {
            System.out.println(nome + " ha già usato la super mossa!");
            return;
        }

        int danno = (int) (attacco * 1.8);
        nemico.riceviDanno(danno);
        superMossaUsata = true;

        System.out.println(nome + " usa la SUPER MOSSA su " + nemico.nome + "!");
    }

    public void megaEvoluzione() {
        if (megaEvoluto) {
            System.out.println(nome + " è già megaevoluto!");
            return;
        }

        attacco += 10;
        difesa += 10;
        megaEvoluto = true;

        System.out.println(nome + " si MEGAEVOLVE!");
    }

    public boolean isKo() {
        return hp <= 0;
    }

    public String getNome() { 
return nome;
 }
    public int getHp() { 	
return hp; 
}

    public static double calcolaEfficacia(String attaccante, String difensore) {
        attaccante = attaccante.toLowerCase();
        difensore = difensore.toLowerCase();

        if (attaccante.equals("fuoco")) {
            if (difensore.equals("erba") || difensore.equals("ghiaccio")) return 2.0;
            if (difensore.equals("acqua")) return 0.5;
        }
        if (attaccante.equals("acqua")) {
            if (difensore.equals("fuoco") || difensore.equals("terra")) return 2.0;
            if (difensore.equals("erba")) return 0.5;
        }
        if (attaccante.equals("terra") && difensore.equals("elettrico")) return 2.0;
        if (attaccante.equals("elettrico") && difensore.equals("terra")) return 0.0;
        if (attaccante.equals("buio") && difensore.equals("psico")) return 2.0;
        if (attaccante.equals("psico") && difensore.equals("buio")) return 0.5;

        return 1.0;
    }
}








